# Gmail OAuth Configuration
# IMPORTANT: VITE_GMAIL_CLIENT_SECRET must NOT be set here.
# The client secret must only live in a Supabase Edge Function (server-side).
# Setting it as a VITE_ variable compiles it into the public JS bundle.
VITE_GMAIL_CLIENT_ID=your_google_client_id_here

# EmailJS Configuration
# NOTE: Do NOT add VITE_EMAILJS_PRIVATE_KEY — private keys must never be in the frontend bundle.
# The EmailJS browser SDK only requires the public key.
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_WELCOME_TEMPLATE_ID=your_welcome_template_id
VITE_EMAILJS_PAYMENT_VERIFICATION_TEMPLATE_ID=your_payment_verification_template_id

# Admin EmailJS Configuration (for payment verification emails)
VITE_ADMIN_EMAILJS_SERVICE_ID=your_admin_service_id
VITE_ADMIN_EMAILJS_PUBLIC_KEY=your_admin_public_key

# Admin emails (comma-separated) — used for notification emails ONLY, not for access control
VITE_ADMIN_EMAILS=admin@yourdomain.com

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay Configuration
# IMPORTANT: NEVER add VITE_RAZORPAY_KEY_ID or VITE_RAZORPAY_KEY_SECRET here!
# Razorpay credentials must ONLY be stored as Supabase secrets (server-side).
# The payment flow is handled entirely through Edge Functions:
# 1. Frontend calls Edge Function to create order (server validates price)
# 2. Razorpay checkout opens with order_id
# 3. After payment, frontend sends response to Edge Function
# 4. Edge Function verifies signature using RAZORPAY_KEY_SECRET (server-side)
# 5. Only after verification, subscription is activated
# 
# To set Razorpay secrets in Supabase:
# supabase secrets set RAZORPAY_KEY_ID=your_key_id
# supabase secrets set RAZORPAY_KEY_SECRET=your_key_secret

