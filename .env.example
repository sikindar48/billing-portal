# Gmail OAuth Configuration
VITE_GMAIL_CLIENT_ID=your_google_client_id_here
VITE_GMAIL_CLIENT_SECRET=your_google_client_secret_here

# EmailJS Configuration
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_WELCOME_TEMPLATE_ID=your_welcome_template_id
VITE_EMAILJS_PAYMENT_VERIFICATION_TEMPLATE_ID=your_payment_verification_template_id

# Admin EmailJS Configuration (for payment verification emails)
VITE_ADMIN_EMAILJS_SERVICE_ID=your_admin_service_id
VITE_ADMIN_EMAILJS_PUBLIC_KEY=your_admin_public_key

# Admin emails (comma-separated)
VITE_ADMIN_EMAILS=admin@yourdomain.com
