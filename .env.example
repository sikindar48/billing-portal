# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Resend (Primary Email Provider - Server-side via Supabase Edge Functions)
# Used for: OTP/Password Reset, Subscription Confirmations
# IMPORTANT: RESEND_API_KEY must be set as a Supabase secret (NOT as VITE_ variable)
# Command: supabase secrets set RESEND_API_KEY=re_xxxxx
# The key is accessed only by the send-email edge function (server-side)

# EmailJS (Invoice Sending for Trial/Free Users - Client-side)
# Used for: Invoice emails with user branding (Trial/Free plan only)
# Pro users send invoices via their own Gmail OAuth connection
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_INVOICE_TEMPLATE_ID=your_invoice_template_id

# NOTE: The following EmailJS templates are NO LONGER USED (migrated to Resend):
# - VITE_EMAILJS_PASSWORD_RESET_TEMPLATE_ID (now: Resend OTP)
# - VITE_EMAILJS_SUBSCRIPTION_TEMPLATE_ID (now: Resend subscription_confirmation)
# - VITE_EMAILJS_PAYMENT_VERIFICATION_TEMPLATE_ID (removed - not needed)
# - VITE_EMAILJS_ADMIN_SERVICE_ID (removed - not needed)
# - VITE_EMAILJS_ADMIN_PUBLIC_KEY (removed - not needed)

# ============================================================================
# GMAIL OAUTH CONFIGURATION (Pro Plan Feature)
# ============================================================================

# Gmail OAuth - Used for Pro users to send invoices from their own Gmail
# IMPORTANT: VITE_GMAIL_CLIENT_SECRET must NOT be set here.
# The client secret must only live in a Supabase Edge Function (server-side).
# Setting it as a VITE_ variable compiles it into the public JS bundle.
VITE_GMAIL_CLIENT_ID=your_google_client_id_here

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay Configuration
# IMPORTANT: NEVER add VITE_RAZORPAY_KEY_ID or VITE_RAZORPAY_KEY_SECRET here!
# Razorpay credentials must ONLY be stored as Supabase secrets (server-side).
# The payment flow is handled entirely through Edge Functions:
# 1. Frontend calls Edge Function to create order (server validates price)
# 2. Razorpay checkout opens with order_id
# 3. After payment, frontend sends response to Edge Function
# 4. Edge Function verifies signature using RAZORPAY_KEY_SECRET (server-side)
# 5. Only after verification, subscription is activated
# 
# To set Razorpay secrets in Supabase:
# supabase secrets set RAZORPAY_KEY_ID=your_key_id
# supabase secrets set RAZORPAY_KEY_SECRET=your_key_secret

